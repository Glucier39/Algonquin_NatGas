geom_line(aes(y = chi_hh,  color = "Chicago – Henry Hub"),  size = 1) +
coord_cartesian(ylim = c(-1, 20)) +
labs(
title = "Daily Natural Gas Basis Spreads (Algonquin, Chicago, Henry Hub)",
subtitle = "Algonquin consistently trades at a winter premium due to pipeline constraints\nand reliance on LNG imports into New England",
x = "Date",
y = "Spread ($/MMBtu)",
color = "Spread"
) +
theme_minimal(base_size = 13) +
theme(
plot.title = element_text(face = "bold", size = 15),
plot.subtitle = element_text(size = 11)
)
no_24 %>%
mutate(
alg_hh  = Alg_Price - Hen_Price,
alg_chi = Alg_Price - Chi_Price,
chi_hh  = Chi_Price - Hen_Price
) %>%
ggplot(aes(Date)) +
# Lines with consistent colors
