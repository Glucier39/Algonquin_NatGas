Month %in% c("10","11","12"),
paste0(lubridate::year(Date), "-", lubridate::year(Date) + 1),
paste0(lubridate::year(Date) - 1, "-", lubridate::year(Date))
)
)
seasons <- unique(winter_df$Winter_Season)
