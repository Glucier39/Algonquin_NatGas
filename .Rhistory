library(quantmod)
library(ggplot2)
library(dplyr)
library(lubridate)
getSymbols("^GSPC", from = "2019-01-01", to = "2020-09-01")
sp500 <- data.frame(date = index(GSPC), coredata(GSPC))
sp500 <- sp500 %>%
mutate(return = 100 * (GSPC.Adjusted / lag(GSPC.Adjusted) - 1))
#comes fromr the quantmod package, pulling s&p500 daily prices on the designated dates
# building a date to run event series on. Covid crash
event_date <- as.Date("2020-03-16")
pre_window <- sp500 %>% filter(date >= event_date - 60 & date < event_date)
post_window <- sp500 %>% filter(date > event_date & date <= event_date + 60)
ggplot(sp500 %>% filter(date >= event_date - 60 & date <= event_date + 60),
aes(x = date, y = return)) +
geom_line(color = "steelblue") +
geom_vline(xintercept = as.numeric(event_date), color = "red", linetype = "dashed") +
labs(title = "S&P 500 Returns Around COVID-19 Crash", y = "Daily Return (%)")
#visualisation
View(sp500)
symbols <- c("CL=F", "BZ=F")
for (i in 1:nrow(cyclones)) {
start_date <- cyclones$window_start[i]
end_date   <- cyclones$window_end[i]
cat("Fetching data for Tropical Cyclone", i, "from", start_date, "to", end_date, "\n")
# --- Fetch WTI (West Texas Intermediate) ---
wti <- tryCatch(
getSymbols("CL=F", src = "yahoo", from = start_date, to = end_date, auto.assign = FALSE),
error = function(e) NULL
)
# --- Fetch Brent ---
brent <- tryCatch(
getSymbols("BZ=F", src = "yahoo", from = start_date, to = end_date, auto.assign = FALSE),
error = function(e) NULL
)
# --- Combine if successful ---
if (!is.null(wti) & !is.null(brent)) {
merged <- merge(wti, brent)
names(merged) <- c(
"WTI.Open", "WTI.High", "WTI.Low", "WTI.Close", "WTI.Volume", "WTI.Adjusted",
"Brent.Open", "Brent.High", "Brent.Low", "Brent.Close", "Brent.Volume", "Brent.Adjusted"
)
merged <- data.frame(Date = index(merged), coredata(merged))
merged$Event_ID <- i
merged$Type <- cyclones$Type[i]
price_data_list[[i]] <- merged
}
# small delay to prevent throttling
Sys.sleep(2)
}
