pipes <- st_read("data/naturalgas_interintrastate_pipelines_us_eia.geojson")
basin <- st_read("data/MiddleDevonianMarcellusShaleAUs/")
basin <- st_transform(basin, 4326)
us <- st_as_sf(map("state", plot = FALSE, fill = TRUE))
us <- st_transform(us, 4326)
boston_sf <- st_as_sf(
data.frame(
city = "Boston",
lon = -71.0589,
lat = 42.3601
),
coords = c("lon", "lat"),
crs = 4326
) #manually build boston
chicago_sf <- st_as_sf(
data.frame(
city = "Chicago",
lon = -87.6298,
lat = 41.8781
),
coords = c("lon", "lat"),
crs = 4326
) # same with chicago
ggplot() +
# US map first
geom_sf(
data = us,
fill = "gray85",
color = "white"
) +
# Pipeline layer on top
geom_sf(
data = pipes,
color = "red",
size = 0.2,
alpha = 0.8
) +
coord_sf() +
theme_minimal() +
labs(
title = "U.S. Natural Gas Pipeline Network",
x = "",
y = ""
)
