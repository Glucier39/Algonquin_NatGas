library(tidyverse)
setwd("~/Documents/ECON2300/")
wages <- read_csv("Minimum_wage.csv")
df <- wages %>% mutate(Effect = After_MW - Before_MW)
# Split into NJlow and NJhigh
df_low  <- df %>% filter(Group == "NJlow")
df_high <- df %>% filter(Group == "NJhigh")
# Compute DeltaLow and DeltaHigh
DeltaLow  <- mean(df_low$After_MW)  - mean(df_low$Before_MW)
DeltaHigh <- mean(df_high$After_MW) - mean(df_high$Before_MW)
# Estimator of difference
theta_hat <- DeltaLow - DeltaHigh
# Sample variances of the effect
var_low  <- var(df_low$Effect)
var_high <- var(df_high$Effect)
# Sample sizes
n_low  <- nrow(df_low)
n_high <- nrow(df_high)
# Standard error for difference in means
SE <- sqrt( var_low/n_low + var_high/n_high )
# Test statistic
Tn <- abs(theta_hat / SE)
# Critical value for alpha = 0.1
alpha <- 0.1
critical_value <- qnorm(1 - alpha/2)
# Print results
if (Tn > critical_value) {
print("Reject H0: The effects differ between NJlow and NJhigh")
} else {
print("Fail to reject H0: No evidence of different effects")
}
