subtitle = "Consistent color scheme calibrated to hub prices (Algonquin, Chicago, Henry Hub)",
x = "Date",
y = "Spread ($/MMBtu)"
) +
theme_minimal(base_size = 13) +
theme(
plot.title = element_text(face = "bold", size = 15),
plot.subtitle = element_text(size = 11)
