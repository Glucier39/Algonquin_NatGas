symbols <- c("CL=F", "BZ=F")
price_data_list <- list()
symbols <- c("CL=F", "BZ=F")
price_data_list <- list()
for (i in 1:nrow(disasters_clean)) {
start_date <- disasters_clean$window_start[i]
end_date   <- disasters_clean$window_end[i]
cat("Fetching data for window:", start_date, "to", end_date, "\n")
# Fetch WTI
wti <- tryCatch({
getSymbols(Symbols = "CL=F", src = "yahoo",
from = start_date, to = end_date,
auto.assign = FALSE)
}, error = function(e) NULL)
# Fetch Brent
brent <- tryCatch({
getSymbols(Symbols = "BZ=F", src = "yahoo",
from = start_date, to = end_date,
auto.assign = FALSE)
}, error = function(e) NULL)
# Combine if both exist
if (!is.null(wti) & !is.null(brent)) {
merged <- merge(Cl(wti), Cl(brent))
names(merged) <- c("WTI_Close", "Brent_Close")
merged <- data.frame(Date = index(merged), coredata(merged))
merged$Event_ID <- i
merged$Type <- disasters_clean$Type[i]
price_data_list[[i]] <- merged
}
# Slow down requests to avoid throttling
Sys.sleep(2)
}
