# Difference line (Brent - WTI)
geom_line(aes(y = close_diff, color = "Brent-WTI Spread"), linewidth = 0.8, na.rm = TRUE) +
labs(
title = "Brent-WTI Spread Across Texas Weather Disasters (2024)",
y = "Price Difference (USD)",
x = "Date",
color = "Series",
fill  = "Disaster Type"
) +
scale_color_manual(values = c("Brent-WTI Spread" = "black")) +
scale_fill_manual(values = c(
"Winter Storm"     = "#4DB3FF",   # bright icy blue
"Tropical Cyclone" = "#00CC44",   # bright green
"Severe Storm"     = "#FF3333"    # bright red
)) +
theme_bw()
ggplot(oil_disaster, aes(x = Date)) +
# Highlight full vertical span for disaster periods
geom_rect(
data = oil_disaster %>% filter(!is.na(Type)) %>% distinct(Event, Type, Begin.Date, End.Date),
aes(xmin = Begin.Date, xmax = End.Date,
ymin = -Inf, ymax = Inf, fill = Type),
inherit.aes = FALSE, alpha = 0.2
) +
# Difference line (Brent - WTI)
geom_line(aes(y = close_diff, color = "Brent-WTI Spread"), linewidth = 0.8, na.rm = TRUE) +
labs(
title = "Brent-WTI Pricing Difference Across Texas Weather Disasters (2024)",
y = "Price Difference (USD)",
x = "Date",
color = "Series",
fill  = "Disaster Type"
) +
scale_color_manual(values = c("Brent-WTI Spread" = "black")) +
scale_fill_manual(values = c(
"Winter Storm"     = "#4DB3FF",   # bright icy blue
"Tropical Cyclone" = "#00CC44",   # bright green
"Severe Storm"     = "#FF3333"    # bright red
)) +
theme_bw()
library(ggplot2)
set.seed(123)
sides = c(1,2,3,4,5,6)
med9 = median(sample(sides, size = 8, replace = TRUE)) # remaining die
exp1 = function(){
num1 = sample(sides, size = 1, replace = TRUE) # first die
med9 = median(sample(sides, size = 8, replace = TRUE)) # remaining die
if (num1 > med9){
return(1)
}
else{
return(0)
}
}
rounds = 10000
rounds = sum(replicate(n = rounds, expr = strategy_a()))/rounds
rounds = sum(replicate(n = rounds, expr = exp1()))/rounds
rounds = 10000
prob1 = sum(replicate(n = rounds, expr = exp1()))/rounds
print(1)
print(prob1)
set.seed(153)
rounds = 10000
sides = c(1,2,3,4,5,6)
exp1 = function(){
num1 = sample(sides, size = 1, replace = TRUE) # first die
med9 = median(sample(sides, size = 8, replace = TRUE)) # remaining die
if (num1 > med9){
return(1)
}
else{
return(0)
}
}
prob1 = sum(replicate(n = rounds, expr = exp1()))/rounds
print(prob1)
exp1 = function(){
num1 = sample(sides, size = 1, replace = TRUE) # first die
med9 = median(sample(sides, size = 9, replace = TRUE)) # remaining die
if (num1 > med9){
return(1)
}
else{
return(0)
}
}
prob1 = sum(replicate(n = rounds, expr = exp1()))/rounds
print(prob1)
